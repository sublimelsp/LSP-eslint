{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>sublimelsp/renovate-preset"
  ],
  "npm": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^plugin\\.py$/"
      ],
      "matchStrings": [
        "TAG = '(?<currentValue>.+?)'"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "microsoft/vscode-eslint",
      "versioningTemplate": "regex:^release/(?<major>\\d+).(?<minor>\\d+).(?<patch>\\d+)$"
    }
  ]
}
